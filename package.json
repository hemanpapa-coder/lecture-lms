{
  "name": "lecture-lms",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "build": {
    "appId": "com.neuracoust.roomsimulator",
    "productName": "Neuracoust Room Simulator",
    "directories": {
      "output": "dist_electron"
    },
    "mac": {
      "category": "public.app-category.music"
    },
    "asar": false,
    "files": [
      "main.js",
      "package.json",
      ".next/standalone/**/*"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "postbuild": "mkdir -p .next/standalone/.next && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public",
    "start": "next start",
    "lint": "eslint",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "npm run build && electron-builder",
    "electron": "electron ."
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "cookie": "^0.6.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^12.7.0",
    "googleapis": "^171.4.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.4.1",
    "next": "16.1.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-quill": "^2.0.0",
    "react-quill-new": "^3.8.3",
    "resend": "^6.9.3",
    "wavesurfer.js": "^7.12.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jszip": "^3.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
